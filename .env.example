# Redpanda Cloud connection
REDPANDA_BOOTSTRAP_SERVERS=your-cluster.cloud.redpanda.com:9092
REDPANDA_SASL_USERNAME=your-username
REDPANDA_SASL_PASSWORD=your-password
REDPANDA_SASL_MECHANISM=SCRAM-SHA-256

# Anthropic API (agent LLM)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Salt for the hash redaction strategy (optional; defaults to empty if unset)
REDACTION_HASH_SALT=change-me
